# Optional: server-side ntfy on PC online/offline and scheduled alerts (app.py)
NTFY_URL=https://ntfy.sh/your-secret-topic

# Tap notification opens HUD (Tailscale dashboard URL)
NTFY_CLICK_URL=http://100.88.171.98:8080/

# Optional: custom notification icon (Android only; ntfy fetches server-side)
# Must be a publicly reachable HTTPS URL. See pi/static/ICON_HOSTING.md.
NTFY_ICON_URL=https://raw.githubusercontent.com/ForeigndevX/pi/main/static/wolapp-icon.png

# Optional: large image in expanded notification (iOS may show below text, not as app icon)
# Use 512×512 PNG when possible. Defaults to NTFY_ICON_URL if unset.
NTFY_ATTACH_URL=https://raw.githubusercontent.com/ForeigndevX/pi/main/static/wolapp-notify-512.png

# Optional: subscribe phone ntfy app to same or dedicated topic (document only)
# NOTIFY_PHONE_NTFY_TOPIC=your-phone-topic

# Optional: HTTP notifier on phone (Tasker/Macrodroid/etc. listening on Tailscale)
# NOTIFY_PHONE_URL=http://100.123.104.48:8080/notify

# Optional: Pushover (iOS app supports custom notification icons per app)
# Do not enable unless you use Pushover; wire-up is not enabled by default.
# PUSHOVER_USER_KEY=
# PUSHOVER_API_TOKEN=

